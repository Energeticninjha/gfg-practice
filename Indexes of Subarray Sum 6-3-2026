
class Solution {
    static ArrayList<Integer> subarraySum(int[] arr, int target) {
        // code here
        int sum =0;
        int left = 0;
        ArrayList<Integer> ans = new ArrayList<>();
for(int right = 0;right<arr.length;right++){
    sum += arr[right];
    while(sum>target && left<right){
        sum -= arr[left];
        left++;
    }
    if(sum == target){
        ans.add(left+1);
        ans.add(right+1);
        return ans;
    }
    
}
ans.add(-1);
return ans;
    }
}
